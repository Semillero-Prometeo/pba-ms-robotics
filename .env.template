NATS_SERVER=nats://nats-server:4222
PORT=3003
ENV=development

# --- Voice / TTS (optional) ---
#
# PULSE_SINK=
#   Nombre del sink de PulseAudio/PipeWire donde reproducir (salida de ``pactl list short sinks``,
#   columna "Name"). Déjalo vacío para heurística automática (prioridad: Bluetooth/bluez, luego USB).
#
# PIPER_MODEL_PATH=
#   Ruta absoluta al fichero ``.onnx`` del modelo Piper (síntesis neuronal offline, mejor calidad).
#   Descarga recomendada:
#   - Repositorio de voces: https://huggingface.co/rhasspy/piper-voices
#   - Ejemplo español: busca ``es_ES`` (p. ej. ``es_ES-lessac-medium``), descarga el ``.onnx``
#     y el ``.onnx.json`` en la **misma carpeta** que el modelo.
#   - Instala el binario ``piper`` (https://github.com/rhasspy/piper/releases) o vía paquete del SO.
#   Ejemplo de valor:
#   PIPER_MODEL_PATH=/opt/piper/es_ES-lessac-medium.onnx
#
# ESPEAK_VOICE=es
#   Voz para el fallback ``espeak-ng`` cuando Piper no está configurado o falla.
#   ``es`` = español genérico. Lista: ``espeak-ng --voices`` (p. ej. ``es-mx``, ``es-la`` si existen).
#
# VOICE_SKIP_PLAYBACK=0
#   Si es ``1`` / ``true``: genera el WAV con TTS pero **no** intenta reproducir (útil en Docker sin
#   tarjeta de sonido para probar solo la síntesis).
