NATS_SERVER=nats://nats-server:4222
PORT=3003
ENV=development

# --- Voice / TTS local (Piper / espeak) ---
#
# PIPER_MODEL_PATH=
#   Dentro del contenedor Docker: ``/usr/src/app/src/core/models/voice/TU_MODELO.onnx``
# PULSE_SERVER=unix:/run/user/TU_UID/pulse/native
# PULSE_SINK=
# ESPEAK_VOICE=es
# VOICE_SKIP_PLAYBACK=0

# --- TTS OpenAI (online; fallback automático a local si falla red/API) ---
#
# VOICE_TTS_MODE=auto
#   ``auto`` | ``openai`` | ``local``. ``auto`` / ``openai``: intentan OpenAI si hay clave.
#   ``local``: solo Piper/espeak (sin llamadas a internet para TTS).
#
# OPENAI_API_KEY=
#   En Compose suele pasarse desde el ``.env`` del launcher (``MS_MANAGEMENT_OPENAI_API_KEY``
#   o ``MS_ROBOTICS_OPENAI_API_KEY``).
#
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy
# OPENAI_TTS_SPEED=
# OPENAI_TTS_TIMEOUT=60
