NATS_SERVER=nats://nats-server:4222
PORT=3003
ENV=development

# --- Voice / TTS ---
#
# PIPER_MODEL_PATH=
#   Ruta absoluta al ``.onnx`` dentro del contenedor Docker. El proyecto se monta en ``/usr/src/app``:
#     /usr/src/app/src/core/models/voice/TU_MODELO.onnx
#   Coloca también el ``.onnx.json`` junto al ``.onnx``. Si omites esta variable, se usa el primer
#   ``*.onnx`` encontrado en ``src/core/models/voice``.
#
# PULSE_SERVER=
#   En Docker **no** hay PulseAudio por defecto → ``paplay`` falla con "Connection refused".
#   Para reproducir por el **mismo** Pulse del host (donde suele estar el Bluetooth):
#     PULSE_SERVER=unix:/run/user/TU_UID/pulse/native
#   y monta en ``docker-compose`` el socket (ver comentarios junto al servicio ``pba-ms-robotics``).
#
# PULSE_SINK=
#   Nombre del sink (``pactl list short sinks``). Vacío = prioridad Bluetooth (bluez), luego USB.
#
# ESPEAK_VOICE=es
#
# VOICE_SKIP_PLAYBACK=0
#   ``1`` = solo generar WAV, no reproducir (útil sin audio en el contenedor).
