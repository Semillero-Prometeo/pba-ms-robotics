FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# ---- Sistema base + dependencias ----
RUN apt-get update && apt-get install -y --no-install-recommends \
    pulseaudio-utils \
    alsa-utils \
    espeak-ng \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# ---- Instalar Piper (tags en GitHub son por fecha, p. ej. 2023.11.14-2, no semver v1.x) ----
ARG PIPER_RELEASE=2023.11.14-2

RUN curl -fSL -o /tmp/piper.tar.gz \
    "https://github.com/rhasspy/piper/releases/download/${PIPER_RELEASE}/piper_linux_x86_64.tar.gz" \
    && tar -xzf /tmp/piper.tar.gz -C /tmp \
    && mv /tmp/piper /opt/piper \
    && ln -s /opt/piper/piper /usr/local/bin/piper \
    && rm /tmp/piper.tar.gz \
    && test -x /opt/piper/piper

# (Opcional) carpeta para modelos
RUN mkdir -p /opt/piper/models

# ---- Python ----
RUN pip install --upgrade pip

WORKDIR /usr/src/app

COPY pyproject.toml ./
COPY src/ ./src/

RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -e ".[dev]"

EXPOSE 9233